# Capacitor discovers native plugins by walking node_modules for each dependency's android/ and ios/ folders. pnpm's
# default strict, symlinked layout hides those nested package paths, so `cap sync` finds no plugins. Hoisting the
# dependency tree (the npm/yarn layout) restores discovery. Required because this demo defaults to pnpm.
node-linker=hoisted

# Disable pnpm's pre-run dependency check (mirror of verifyDepsBeforeRun in pnpm-workspace.yaml) so `pnpm run` /
# `pnpm exec` inside the Docker build don't try to reinstall and purge node_modules — which aborts with no TTY. Kept
# here too for older pnpm/tooling that still reads .npmrc.
verify-deps-before-run=false
